{
  "name": "@univerjs/icons-workspace",
  "version": "1.28.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "Icons used by Univer",
  "author": "DreamNum Co., Ltd. <developer@univer.ai>",
  "license": "MIT",
  "repository": "https://github.com/dream-num/univer-icons.git",
  "sideEffects": false,
  "main": "index.js",
  "devEngines": {
    "runtime": [
      {
        "name": "node",
        "range": ">=22.18"
      },
      {
        "name": "pnpm",
        "range": ">=11"
      }
    ]
  },
  "scripts": {
    "build": "pnpm --filter @univerjs/icons-svg run prepare && pnpm --filter ./packages/icons run build && pnpm --filter ./packages/icons-vue run build",
    "dev": "pnpm --filter ./packages/app dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:staged": "lint-staged",
    "prepare": "simple-git-hooks",
    "release": "verso"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@univerkit/verso": "1.0.0-rc.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "7.0.1-rc"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint:staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,cts,mjs,mts}": "oxlint",
    "*.{md,markdown,yml,yaml}": "oxfmt --check ."
  }
}
