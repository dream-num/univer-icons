{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "./ts",
    "outDir": "./dist/esm",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["./ts"],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
