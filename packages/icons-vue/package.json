{
  "name": "@univerjs/icons-vue",
  "version": "1.15.0",
  "description": "Vue icons for Univer.",
  "author": "DreamNum Co., Ltd. <developer@univer.ai>",
  "license": "MIT",
  "homepage": "https://docs.univer.ai/icons",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dream-num/univer-icons"
  },
  "bugs": {
    "url": "https://github.com/dream-num/univer-icons/issues"
  },
  "keywords": [
    "icons",
    "univer",
    "vue"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#build/*": "./scripts/build/*.mts"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "main": "dist/esm/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node --experimental-strip-types ./scripts/build/index.mts && tsc"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/svg-parser": "^2.0.6",
    "@univerjs/icons-svg": "workspace:*",
    "rolldown": "1.1.3",
    "svg-parser": "^2.0.4",
    "svgo": "^4.0.1",
    "typescript": "^6.0.3",
    "vue": "^3.5.39"
  }
}
